    @overload
    def ones(sp: Sparsity) -> DM: ...
    @staticmethod
    def eye(n: int) -> DM: ...
    def size1(self) -> int: ...
    def size2(self) -> int: ...
    def full(self) -> Any: ...
    def sparse(self) -> Any: ...
    def __add__(self, other: Any) -> DM: ...
    def __sub__(self, other: Any) -> DM: ...
    def __mul__(self, other: Any) -> DM: ...
    def __truediv__(self, other: Any) -> DM: ...
    def __neg__(self) -> DM: ...
    def __getattr__(self, name: str) -> Any: ...


