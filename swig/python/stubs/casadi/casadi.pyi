from __future__ import annotations

from typing import Any, List, Mapping, Sequence, Tuple, overload

__version__: str


class Sparsity:
    def __init__(self, *args: Any) -> None: ...
    shape: Tuple[int, int]
    T: Sparsity
    @staticmethod
    def dense(nrow: int, ncol: int = ...) -> Sparsity: ...
    @staticmethod
    def diag(n: int) -> Sparsity: ...
    def size1(self) -> int: ...
    def size2(self) -> int: ...
    def __getattr__(self, name: str) -> Any: ...


